# ──────────────────────────────────────────────
# Payment Service — Environment Variables
# ──────────────────────────────────────────────

# ── Application ──────────────────────────────
APP_NAME=Payment Service
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# ── API Security ─────────────────────────────
ADMIN_API_KEY=your-admin-api-key-here

# ── EGS Auth Service ────────────────────────
# URL of the EGS Auth Service (used for token verification)
AUTH_SERVICE_URL=http://host.docker.internal:8000
# Shared secret key — must match INTERNAL_SERVICE_KEY in the Auth Service .env
INTERNAL_SERVICE_KEY=change-me-in-production

# ── Database (PostgreSQL) ────────────────────
DATABASE_URL=postgresql+asyncpg://payment_user:payment_pass@postgres:5432/payment_db

# ── Redis ────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Rate Limiting (global defaults) ──────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ── Logging ──────────────────────────────────
LOG_LEVEL=INFO

# ── OpenTelemetry ────────────────────────────
# Set to false to disable tracing and metrics collection
OTEL_ENABLED=true
# Service name shown in Jaeger and Grafana
OTEL_SERVICE_NAME=payment-service
# OTel Collector endpoint (gRPC)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# Metric export interval in milliseconds
OTEL_METRIC_EXPORT_INTERVAL_MS=5000
