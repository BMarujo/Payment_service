# ──────────────────────────────────────────────
# Payment Service — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ── Application ──────────────────────────────
APP_NAME=Payment Service
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# ── API Security ─────────────────────────────
# Admin API key for managing tenant API keys (bootstrap key)
# This key has full access to create, list, update, and revoke tenant keys
ADMIN_API_KEY=your-admin-api-key-here

# ── JWT ──────────────────────────────────────
JWT_SECRET=change-me-jwt-secret-in-production

# ── Database (PostgreSQL) ────────────────────
DATABASE_URL=postgresql+asyncpg://payment_user:payment_pass@postgres:5432/payment_db

# ── Redis ────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Rate Limiting (global defaults) ──────────
# Tenant keys can override these with per-key settings
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ── Logging ──────────────────────────────────
LOG_LEVEL=INFO
